{
  "name": "chchchchanges",
  "version": "1.0.0",
  "description": "Desktop pull request review app for GitHub and Bitbucket.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"bun run dev:renderer\" \"bun run dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on http://127.0.0.1:5173 && tsc -p electron/tsconfig.json && electron .",
    "build": "tsc --noEmit && vite build && tsc -p electron/tsconfig.json",
    "dist:mac": "bun run build && electron-builder --mac --publish never",
    "cask:update": "bun scripts/update-homebrew-cask.mjs",
    "cask:check": "ruby -c Casks/chchchchanges.rb",
    "preview": "vite preview --host 127.0.0.1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "lol.vos.chchchchanges",
    "productName": "Chchchchanges",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "protocols": [
      {
        "name": "Chchchchanges OAuth",
        "schemes": [
          "chchchchanges"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    }
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.18.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "wait-on": "^9.0.5"
  }
}
